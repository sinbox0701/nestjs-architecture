{
  "$schema": "https://json.schemastore.org/swcrc",
  "sourceMaps": true,
  "inlineSourcesContent": true,
  "module": {
    "type": "commonjs"
  },
  "jsc": {
    "target": "es2022",
    "parser": {
      "syntax": "typescript",
      "decorators": true,
      "dynamicImport": true
    },
    "transform": {
      "legacyDecorator": true,
      "decoratorMetadata": true
    },
    "keepClassNames": true,
    "baseUrl": "./src",
    "paths": {
      "@/*": ["*"]
    }
  }
}
