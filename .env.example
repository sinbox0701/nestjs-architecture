# 앱 실행용 환경변수 예시. 복사해서 .env 로 사용한다: cp .env.example .env
# 검증 스키마: src/config/env.schema.ts (부팅 시 zod parse)
#
# ⚠️ prod/stage 안전성 게이트 (APP_ENV=prod|stage 일 때 부팅 거부):
#   - JWT_SECRET / SESSION_SECRET: 기본값 금지 + 최소 32자 (openssl rand -hex 32)
#   - COOKIE_SECURE=true 필수
#   - TRUST_PROXY=true(무한 신뢰) 금지 — 홉 수(정수)나 IP 지정
# (SWAGGER_ENABLED는 운영 정책 선택이라 게이트에서 강제하지 않음 — prod 노출 여부는 직접 결정)

# ── Runtime ──
APP_ENV=dev
NODE_ENV=development
TZ=Etc/UTC
PGTZ=UTC

# ── Application ──
APP_NAME=backend-template
APP_PORT=3000
APP_URL=http://localhost:3000
APP_CORS_URL=http://localhost:5173
SWAGGER_ENABLED=true
LOG_LEVEL=debug
RESPONSE_DEBUG_DETAIL=false

# ── Security & Middleware ──
TRUST_PROXY=false
HELMET_CSP_ENABLED=true
COMPRESSION_ENABLED=true
COMPRESSION_LEVEL=6
COMPRESSION_THRESHOLD=1024

# ── PostgreSQL ──
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=backend_template
POSTGRES_USER=user
POSTGRES_PASSWORD=changeme
MIKRO_ORM_CONNECTION_POOL_MIN=2
MIKRO_ORM_CONNECTION_POOL_MAX=10
MIKRO_ORM_POOL_IDLE_TIMEOUT=30000
ORM_DEBUG=false

# ── Redis ──
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=
# Redis를 필수 의존성으로 둘지(연결 실패 시 부팅 중단). stage/prod 권장: true
REDIS_REQUIRED=false

# ── Cookie ──
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
COOKIE_DOMAIN=

# ── Auth / Session ──
# 로컬은 아래 placeholder로 충분. prod/stage는 반드시 교체: openssl rand -hex 32
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=1h
# 서명/검증 알고리즘 (HMAC 계열: HS256 | HS384 | HS512). 대칭 JWT_SECRET 기반.
JWT_ALGORITHM=HS256
# Refresh Token (AT와 분리된 시크릿). RT는 Redis에 저장되어 rotation/재사용 탐지된다.
REFRESH_TOKEN_SECRET=change-me-in-production
REFRESH_TOKEN_EXPIRES_IN=7d
SESSION_SECRET=change-me-in-production
SESSION_MAX_AGE=86400000
AUTH_MAX_LOGIN_ATTEMPTS=5
AUTH_LOCK_DURATION_MINUTES=30

# ── Mail (골격: 기본 비활성. 도메인 단계에서 provider 연결) ──
MAIL_ENABLED=false
MAIL_FROM=no-reply@localhost

# ── Storage (골격: no-op 드라이버) ──
STORAGE_DRIVER=noop

# ── Observability (OpenTelemetry) ──
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_SERVICE_NAME=backend-template
OTEL_RESOURCE_ATTRIBUTES=
